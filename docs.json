{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Spark",
  "colors": {
    "primary": "#F7B63B",
    "light": "#F7B63B",
    "dark": "#D4941F"
  },
  "appearance": {
    "default": "dark",
    "strict": true
  },
  "background": {
    "decoration": "gradient",
    "color": {
      "dark": "#050810"
    }
  },
  "fonts": {
    "family": "Geist"
  },
  "icons": {
    "library": "lucide"
  },
  "favicon": "/favicon.svg",
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg",
    "href": "https://sparkagents.com"
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Guides",
        "groups": [
          {
            "group": "Introduction",
            "pages": [
              "index"
            ]
          },
          {
            "group": "Two Streams",
            "pages": [
              "streams/activity",
              "knowledge/overview"
            ]
          },
          {
            "group": "Agents",
            "pages": [
              "agents/overview",
              "agents/impact-scorer",
              "agents/built-in",
              "agents/available",
              "agents/agents-page"
            ]
          },
          {
            "group": "Spark AI",
            "pages": [
              "spark/ask-anything"
            ]
          },
          {
            "group": "Knowledge",
            "pages": [
              "knowledge/overview",
              "knowledge/sources",
              "knowledge/pages",
              "knowledge/graph",
              "knowledge/health",
              "knowledge/enrichment"
            ]
          }
        ]
      },
      {
        "tab": "Connect",
        "groups": [
          {
            "group": "API documentation",
            "pages": [
              "api-reference/introduction"
            ]
          },
          {
            "group": "Endpoint examples",
            "pages": [
              "api-reference/endpoint/get",
              "api-reference/endpoint/create",
              "api-reference/endpoint/delete",
              "api-reference/endpoint/webhook"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": []
    }
  },
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "mailto:jd@wayfx.com"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Get Started",
      "href": "https://app.sparkagents.com"
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "perplexity",
      "mcp",
      "cursor",
      "vscode"
    ]
  },
  "footer": {
    "socials": {
      "x": "https://x.com/sparkagents",
      "github": "https://github.com/wayfx-com"
    }
  }
}
